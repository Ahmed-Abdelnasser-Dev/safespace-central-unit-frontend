# ============================================================
# Safe Space DMZ Frontend — Deployment Environment Template
# ============================================================
# Copy this file to .env and fill in the values for your setup.
# This file is safe to commit; .env is gitignored.
#
# Usage:
#   cp .env.deploy.example .env
#   nano .env   # set BACKEND_HOST (and STREAM_HOST if different)
#   docker compose up -d --build

# ── Backend VM (protected layer) ────────────────────────────
# IP address of the VM running the central-unit backend.
# This is a RUNTIME variable — nginx reads it at container start;
# no rebuild needed when it changes.
BACKEND_HOST=10.0.0.X
BACKEND_PORT=5000

# IP address of the VM running the stream-service.
# In most deployments this is the same VM as the backend.
STREAM_HOST=10.0.0.X
STREAM_PORT=4001

# ── DMZ listen port ─────────────────────────────────────────
# Host port to expose the frontend on. Default 80.
HTTP_PORT=80

# ── Build-time config ───────────────────────────────────────
# Relative path so the SPA uses the DMZ reverse proxy for all
# API traffic (same-origin, no CORS, cookies just work).
# Change this ONLY if you are NOT using the built-in nginx proxy.
VITE_API_URL=/api

# ── Nginx envsubst filter ───────────────────────────────────
# Only substitute our custom BACKEND_* and STREAM_* vars;
# leaves nginx's own $uri, $host, $http_upgrade, etc. untouched.
NGINX_ENVSUBST_FILTER=^(BACKEND_|STREAM_)
