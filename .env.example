# Safe Space Frontend Environment Template
# Copy to .env (dev) or set as container env vars (production).

# API and realtime endpoints
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Stream-service WebSocket base.
# Dev:  ws://localhost:4001
# Prod (DMZ): wss://streams.yourdomain.com
# The Vite dev server derives the HTTP proxy target from this value automatically.
VITE_NODE_VIDEO_WS_URL=ws://localhost:4001

# Enable proxying /api, /socket.io and /uploads through the Vite dev server.
# /stream-service is always proxied regardless of this flag.
VITE_ENABLE_DEV_PROXY=true
VITE_DEV_PROXY_TARGET=http://localhost:5000
